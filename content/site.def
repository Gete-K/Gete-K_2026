; ============================================================
; 劇団サイト 編集ファイル（超初心者向け）
; ファイル名：site.def
;
; ▼ このファイルの役割
; ・ホームページの文章・日程・メンバーなどを変更するためのファイル
; ・HTMLやコードは一切触らない
; ・このファイルだけ編集すればOK
;
; ▼ 編集ルール（絶対守る）
; 1) 左側（key）は絶対に消さない
; 2) 「=」の右側だけを書き換える
; 3) 空行はOK
; 4) 行の先頭が「;」の行は説明なので消してもOK
; 5) 文字は日本語OK
; 6) 画像は「公開してよいWeb用画像」だけを使う
; 7) URLがまだ無い項目は空のままでOK
; 8) 文章を改行したいときは「\n」と書く（例：1行目\n2行目）
; 9) 画像やURLを使わない場合は「なし」と書いてOK
;
; ▼ 写真の注意
; ・劇団員写真は、本人の掲載許可を取ってから使う
; ・元画像や高解像度画像はGitHubに置かない
; ・EXIFや位置情報を削除してから使う
; ・ファイル名に本名や撮影場所を入れない
;
; ▼ 保存方法
; 編集したら保存 → GitHubにアップロード → 反映
; ============================================================



; ============================================================
; 0) META（検索やブラウザの表示）
; ============================================================

; サイトタイトル（ブラウザのタブに表示される）
meta.siteTitle = 劇団XX｜公式サイト

; Google検索で表示される説明文
meta.description = 劇団〇〇の公式サイトです。次回公演情報、News、スケジュール、メンバーを掲載しています。

; サイトのテーマカラー（基本そのままでOK）
meta.themeColor = #B23A3A

; ============================================================
; 0.5) THEME（配色）
; ============================================================
; ▼ 順番に試す場合は、下の値を差し替えて保存してください。
; 1) theater-classic  = 墨黒 + 深い赤 + 生成り（一番おすすめ）
; 2) black-gold       = 黒 + 金（現代的・高級感）
; 3) literary-green   = 墨黒 + くすみ緑（静かな文芸系）
; 4) pop-red          = 黒紫 + 明るい赤（若くSNS寄り）
theme.palette = theater-classic 

; SNSでURLを貼ったときの見え方（分からなければ空でOK）
meta.ogTitle = 劇団XX｜公式サイト
meta.ogDescription = 次回公演情報・スケジュール・最新Newsはこちら
meta.ogImage =
meta.ogUrl =



; ============================================================
; 1) ヘッダー / フッター
; ============================================================

; 日本語団体名
branding.troupeNameJp = 劇団XX

; 英語団体名
branding.troupeNameEn = GEKIDAN XX

; ヘッダーの「劇団XX」の左に出す画像ロゴ
; 空欄または「なし」なら画像は表示されず、文字だけになります。
; 例：branding.logo.src = ./assets/public/branding/logo.png
branding.logo.src = なし
branding.logo.alt =



; ============================================================
; 2) トップページ（HERO）
; ============================================================

; 上に表示される小さい文字
hero.badge = NEXT STAGE

; 公演タイトル
hero.title = 『作品タイトル』

; キャッチコピー（1～2行）
; 改行したい場合：hero.lead = 1行目\n2行目
hero.lead = ここにキャッチコピーを書きます。

; ===== 日程カード =====
hero.meta1.label = 日程
hero.meta1.value = 2026.03.14–03.16

; ===== 会場カード =====
hero.meta2.label = 会場
hero.meta2.value = 〇〇シアター

; ===== 料金カード =====
hero.meta3.label = 料金
hero.meta3.value = 前売 ¥3,500

; ===== ボタン1 =====
; URLを消すとボタンは表示されません
; 予約フォームが未定なら、いったん空にしてOKです
hero.reserve.label = チケット予約
hero.reserve.url = https://example.com

; ===== ボタン2 =====
hero.detail.label = 公演詳細
hero.detail.url =

; ===== 注意書き =====
hero.note = ※ 内容は変更になる場合があります。

; ===== キービジュアル =====
; 画像は、公開してよいWeb用画像だけ使います。
; リポジトリ内に置く場合の例：./assets/public/keyvisual.jpg
; 外部URLを使う場合の例：https://example.com/keyvisual.jpg
; 使わない場合：なし
hero.keyVisual.src = なし
hero.keyVisual.alt =



; ============================================================
; 3) NEWS（お知らせ）
; ============================================================

; ▼ 新しく追加する方法
; news.3.date =
; news.3.title =
; news.3.text =
; news.3.url =
;
; ▼ URLがある場合
; news.3.url = https://example.com/news
; URLが空なら、見出しはリンクなしの普通の文字になります

news.1.date = 2026-03-01
news.1.title = 次回公演の情報を公開しました
news.1.text = 予約開始日・会場などを更新しました。
news.1.url =

news.2.date = 2026-02-20
news.2.title = 稽古場日記を更新
news.2.text = 最新の稽古写真を追加しました。
news.2.url =



; ============================================================
; 4) SCHEDULE（スケジュール）
; ============================================================

; セクション説明文
schedule.sub = 今後のスケジュール

; 注意書き
schedule.note = ※ 内容は変更になる場合があります。

schedule.1.date = 2026.02.14–02.16
schedule.1.title = 第3回公演『作品タイトル』
schedule.1.place = 〇〇シアター
schedule.1.note = チケット発売中
schedule.1.url =

schedule.2.date = 2026.01.10
schedule.2.title = 稽古開始
schedule.2.place =
schedule.2.note =
schedule.2.url =



; ============================================================
; 5) ABOUT（劇団について）
; ============================================================

about.sub = 私たちは、感情の輪郭を丁寧に描く小劇団です。

about.conceptTitle = コンセプト
about.concept = ここにコンセプトを書く

about.historyTitle = 沿革

history.1.year = 2023
history.1.text = 劇団結成

history.2.year = 2024
history.2.text = 第1回公演『〇〇』



; ============================================================
; 6) MEMBERS（メンバー）
; ============================================================

; enabled = true なら表示
; false にすると非表示
;
; ▼ 劇団員写真のルール
; ・本人から公式サイト掲載の許可を取る
; ・未成年の場合は保護者の同意も取る
; ・Web用にリサイズし、EXIF/位置情報を削除する
; ・ファイル名に本名を入れない（member-01.jpg などにする）
; ・公開してよい画像だけ assets/public/members/ に置く
;
; photo の例：./assets/public/members/member-01.jpg
; 写真を載せない場合：なし
; snsUrl が空ならSNSリンクは表示されません

members.1.enabled = true
members.1.name = 山田太郎
members.1.role = 代表
members.1.note =
members.1.photo = なし
members.1.snsLabel = X
members.1.snsUrl = なし

members.2.enabled = true
members.2.name = 佐藤花子
members.2.role = 役者
members.2.note =
members.2.photo = なし
members.2.snsLabel = Instagram
members.2.snsUrl = なし



; ============================================================
; 7) SNS（Follow）
; ============================================================

socials.sub = 最新情報は各SNSで発信しています。

socials.1.enabled = true
socials.1.label = X
socials.1.title = 最新情報
socials.1.text = 公演告知など
socials.1.url = なし

socials.2.enabled = true
socials.2.label = YouTube
socials.2.title = 映像
socials.2.text = ティザー動画など
socials.2.url = なし



; ============================================================
; 8) CONTACT（お問い合わせ）
; ============================================================

contact.sub = 出演依頼・取材などはメールでご連絡ください。
contact.email = example@example.com



; ============================================================
; 9) FOOTER
; ============================================================

footer.brand = 劇団〇〇
footer.small = © 2026 GEKIDAN XX
